<%
var first = page.posts.sort("date", "desc").eq(0);
var coverDate = first ? first.date.valueOf() : '';
var coverSrc = theme.welcome_cover || (first && first.cover) || "/img/welcome-cover.jpg";
var mobileCoverSrc = theme.welcome_cover_mobile || (first && (first.cover_mobile || first.mobile_cover)) || '';
var coverPosition = (first && first.cover_position) || theme.cover_position || 'center center';
var mobileCoverPosition = (first && (first.cover_mobile_position || first.mobile_cover_position)) || theme.cover_mobile_position || coverPosition;
function cacheCover(src) {
    if (!src || !coverDate) return src;
    return src + (src.indexOf('?') === -1 ? '?v=' : '&v=') + coverDate;
}
%>
<div id="screen">
    <div id="mark">
        <div class="layer" data-depth="0.4">
            <%- image_tag(cacheCover(coverSrc), {id: "cover", crossorigin: "anonymous", width: 1920, height: 1080, "data-mobile-src": cacheCover(mobileCoverSrc), "data-position": coverPosition, "data-mobile-position": mobileCoverPosition}) %>
        </div>
    </div>
    <div id="vibrant">
        <svg viewbox="0 0 2880 1620" height="100%" preserveaspectratio="xMaxYMax slice">
            <polygon opacity="0.7" points="2000,1620 0,1620 0,0 600,0 "/>
        </svg>
        <div></div>
    </div>
    <div id="header">
        <div>
            <!--<a class="image-logo" href="/"></a>-->
			<% if (theme.local_search.enable){ %>
			<div class="iconfont icon-search switchsearch" href="<%= url_for('/search/') %>" title="搜索"></div>
			<%}%>
            <div class="iconfont icon-menu switchmenu"></div>
        </div>
    </div>
    <% if ( first ) { %>
    <div id="post0">
        <p><%- first.date.locale("zh-cn").format("MMMM DD, YYYY") %></p>
        <h2><%- link_to(first.path, first.title || config.title, {class: "posttitle"}) %></h2>
        <p class="summary"><%- truncate(strip_html(first.content), {length: 60, omission: '...'}) %></p>
    </div>
    <% } %>
</div>
